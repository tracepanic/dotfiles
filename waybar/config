{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 4,

  "modules-left": ["sway/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "backlight", "network", "pulseaudio", "battery"],

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },

  "clock": {
    "format": "{:%a %d %b  %H:%M}",
    "tooltip": false
  },

  "cpu": {
    "interval": 5,
    "format": "CPU {usage}%",
    "tooltip": false
  },

  "memory": {
    "interval": 5,
    "format": "RAM {percentage}%",
    "tooltip": false
  },

   "backlight": {
    "device": "intel_backlight",
    "format": "BRI {percent}%",
    "tooltip": false
  },

  "network": {
    "format-wifi": "WIFI({essid})",
    "format-ethernet": "ETH({ipaddr})",
    "format-disconnected": "OFF",
    "tooltip": false
  },

  "pulseaudio": {
    "format": "VOL {volume}%",
    "format-muted": "MUT {volume}%",
    "tooltip": false
  },

  "battery": {
    "interval": 30,
    "format": "BAT {capacity}%",
    "format-charging": "CHR {capacity}%",
    "tooltip": false,
    "states": {
      "warning": 30,
      "critical": 15
    }
  }
}
