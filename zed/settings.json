// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "text_rendering_mode": "platform_default",
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "outline_panel": {
    "dock": "left",
  },
  "cli_default_open_behavior": "new_window",
  "agent": {
    "default_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
      "enable_thinking": true,
    },
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "tree_view": true,
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "show_edit_predictions": false,
  "edit_predictions": {
    "mode": "subtle",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "buffer_font_size": 14,
  "tab_size": 2,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Frappé",
    "dark": "Catppuccin Mocha",
  },
  "preferred_line_length": 80,
  "soft_wrap": "bounded",
  "languages": {
    "HTML": {
      "formatter": "none",
    },
    "Markdown": {
      "format_on_save": "on",
      "formatter": "prettier",
    },
  },
}
